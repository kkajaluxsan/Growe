# GROWE Backend – copy to .env and fill in values
NODE_ENV=development
PORT=5001
DATABASE_URL=postgresql://user:password@localhost:5432/growe
JWT_SECRET=your-secret-min-32-characters-long
JWT_EXPIRES_IN=7d
FRONTEND_URL=http://localhost:5173
# OAuth (Google)
# GOOGLE_CLIENT_ID=
# Email verification link lifetime (minutes, 15–1440). Default 60.
# VERIFICATION_TOKEN_EXPIRY_MINUTES=60
LOG_LEVEL=info

# Set to 1 to disable CSRF validation (e.g. in development)
# DISABLE_CSRF=1

# Booking reminder: hours before session to send email (default 24)
# BOOKING_REMINDER_HOURS=24

# AI assistant (optional): set Gemini and/or OpenAI. Server uses Gemini first if GEMINI_API_KEY is set.
# GEMINI_API_KEY=
# GEMINI_MODEL=gemini-1.5-flash
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini

# SMTP for email verification (required for production). In development, if SMTP_USER is empty, verification is skipped.
# Set FORCE_EMAIL_VERIFICATION=1 to always send verification email even in development.
SMTP_HOST=localhost
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_SECURE=false
SMTP_FROM="GROWE" <noreply@example.com>
