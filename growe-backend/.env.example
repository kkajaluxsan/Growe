# GROWE Backend — copy to .env and fill in values
NODE_ENV=development
PORT=5001
# Optional: bind address. Default is 127.0.0.1 in development (matches Vite proxy) and 0.0.0.0 in production.
# LISTEN_HOST=0.0.0.0
DATABASE_URL=postgresql://user:password@localhost:5432/growe
JWT_SECRET=your-secret-min-32-characters-long
JWT_EXPIRES_IN=7d

# Public URL of the web app (must match where users open GROWE). Used in verification and password-reset links.
# Production example: FRONTEND_URL=https://app.yourschool.edu
FRONTEND_URL=http://localhost:5173

# OAuth (Google) — required for POST /api/auth/google (same value as VITE_GOOGLE_CLIENT_ID in growe-frontend/.env)
# GOOGLE_CLIENT_ID=your-id.apps.googleusercontent.com

# Email verification: token lifetime (minutes, 15–1440). Default 60.
# VERIFICATION_TOKEN_EXPIRY_MINUTES=60

LOG_LEVEL=info

# Set to 1 to disable CSRF validation (e.g. in development)
# DISABLE_CSRF=1

# Booking reminder: hours before session (default 24). Notifies student and tutor (in-app + email when configured).
# BOOKING_REMINDER_HOURS=24
# “Starting soon” in-app alert ~N minutes before start (runs every 60s on the server). Student + tutor.
# BOOKING_IMMINENT_MINUTES=10

# Chat file uploads — max size in MB (default 25, capped at 50)
# MESSAGING_MAX_FILE_MB=25

# AI assistant — set at least one key or the chat UI stays disabled (Groq-only is fine)
# Groq (free tier): https://console.groq.com/keys
# GROQ_API_KEY=
# GROQ_MODEL=llama-3.3-70b-versatile
# Optional: Google Gemini — https://aistudio.google.com/apikey
# GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.0-flash
# Optional: OpenAI — https://platform.openai.com/api-keys
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini
# Optional provider order (when multiple keys are set), e.g. groq,openai,gemini
# AI_PROVIDER_ORDER=groq,openai,gemini
# AI_PREFER_GROQ=1

# ---------------------------------------------------------------------------
# Resend (HTTP API) — default when RESEND_API_KEY is set
# ---------------------------------------------------------------------------
# Get a key at https://resend.com/api-keys — replace re_xxxxxxxxx with your real API key.
# With a key, outbound mail uses Resend’s HTTP API (set RESEND_FROM to an address on a verified domain for any recipient).
# USE_RESEND_HTTP_API=0 — use Nodemailer instead (SMTP_*), even if RESEND_API_KEY is set.
# RESEND_API_KEY=re_xxxxxxxxx
# RESEND_FROM=noreply@your-verified-domain.com
#
# Without a verified domain, Resend only delivers test mail to your Resend account email.
# Verify a domain: https://resend.com/domains
# ---------------------------------------------------------------------------
# SMTP — required for real verification & password-reset email in production
# ---------------------------------------------------------------------------
#
# Production checklist (deploy):
#   1. NODE_ENV=production
#   2. FRONTEND_URL=https://your-live-domain.com   (must match the URL users open in the browser)
#   3. A real SMTP relay — NOT localhost (MailDev/Mailpit only catch mail on your machine)
#   4. SMTP_FROM must be allowed by your provider (verified domain / sender)
#   5. Optional: EMAIL_CONFIG_STRICT=1 — server exits if email env is unusable for production
#   6. Optional: FORCE_EMAIL_VERIFICATION=true — registration fails if the verification email cannot be sent
#
# Providers (examples — use their docs for exact credentials):
#   SendGrid: SMTP_HOST=smtp.sendgrid.net  SMTP_PORT=587  SMTP_SECURE=false
#             SMTP_USER=apikey  SMTP_PASS=<API key from SendGrid>
#   Resend:   SMTP_HOST=smtp.resend.com  SMTP_PORT=587  SMTP_SECURE=false
#             SMTP_USER=resend  SMTP_PASS=<API key>
#             (Same sandbox as Resend HTTP: without a verified domain, only your Resend account email receives mail.)
#   AWS SES:  use SES SMTP endpoint for your region; verify domain/identity in SES first.
#   Gmail:    use an App Password (Google Account → Security), not your normal password.
#
# Local dev: set RESEND_API_KEY and RESEND_FROM, or SMTP_* (e.g. MailDev: npm run maildev — SMTP_HOST=localhost SMTP_PORT=1025, web UI http://localhost:1080).
#
# If localhost + port 587 with no SMTP_USER, dev remaps SMTP to port 1025 (MailDev). Not applied in production.
#
# SMTP_DISABLED=1 — outbound email disabled (verification / password reset emails will fail).
#
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_SECURE=false
SMTP_FROM="GROWE" <noreply@example.com>
# EMAIL_CONFIG_STRICT=1
# FORCE_EMAIL_VERIFICATION=true
# SMTP_MAX_RETRIES=3
# SMTP_RETRY_DELAY_MS=800
