# GROWE Backend — copy to .env and fill in values
NODE_ENV=development
PORT=5001
DATABASE_URL=postgresql://user:password@localhost:5432/growe
JWT_SECRET=your-secret-min-32-characters-long
JWT_EXPIRES_IN=7d

# Public URL of the web app (must match where users open GROWE). Used in verification and password-reset links.
# Production example: FRONTEND_URL=https://app.yourschool.edu
FRONTEND_URL=http://localhost:5173

# OAuth (Google)
# GOOGLE_CLIENT_ID=

# Email verification: token lifetime (minutes, 15–1440). Default 60.
# VERIFICATION_TOKEN_EXPIRY_MINUTES=60

LOG_LEVEL=info

# Set to 1 to disable CSRF validation (e.g. in development)
# DISABLE_CSRF=1

# Booking reminder: hours before session (default 24)
# BOOKING_REMINDER_HOURS=24

# Chat file uploads — max size in MB (default 25, capped at 50)
# MESSAGING_MAX_FILE_MB=25

# AI assistant (optional)
# GEMINI_API_KEY=
# GEMINI_MODEL=gemini-1.5-flash
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini

# ---------------------------------------------------------------------------
# SMTP — required for production email verification & notifications
# ---------------------------------------------------------------------------
# Set SMTP_HOST (or SMTP_USER for authenticated relay). Without this, outbound
# email is skipped in development; in production the server logs a warning.
#
# Examples:
#   Mailpit/MailHog: SMTP_HOST=localhost  SMTP_PORT=1025  (no SMTP_USER)
#   Gmail / Google Workspace: use an app password; SMTP_SECURE=true for 465
#   SendGrid: SMTP_HOST=smtp.sendgrid.net  SMTP_USER=apikey  SMTP_PASS=<api_key>
#
# Set SMTP_DISABLED=1 only if you intentionally run without mail (not recommended for production).
#
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_SECURE=false
SMTP_FROM="GROWE" <noreply@example.com>
# SMTP_MAX_RETRIES=3
# SMTP_RETRY_DELAY_MS=800
