# Google OAuth (optional — same Client ID as GOOGLE_CLIENT_ID in growe-backend/.env)
VITE_GOOGLE_CLIENT_ID=

# Optional: WebRTC ICE servers as JSON array (defaults to public STUN). Add TURN for strict networks.
# VITE_WEBRTC_ICE_SERVERS=[{"urls":"stun:stun.l.google.com:19302"}]

# Optional: only if you use the Laravel API from the UI
# VITE_LARAVEL_API_BASE_URL=http://127.0.0.1:8000/api
